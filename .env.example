# ==========================================================
# App Tín Dụng - Biến môi trường
# Sao chép file này thành ".env" rồi điền giá trị thật.
# ==========================================================

# Chuỗi kết nối PostgreSQL (Vercel Postgres / Neon / Supabase ...).
# Ví dụ Neon: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/app_tindung?schema=public"

# Khóa bí mật để ký JWT (đổi thành chuỗi ngẫu nhiên đủ dài khi triển khai).
JWT_SECRET="tin_dung_secret_key_2026_chuoi_bi_mat_du_dai_cho_jwt_hs256"

# Thời gian hết hạn token (giờ).
JWT_EXPIRE_HOURS=8
